{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/agent-handoff-packet/v0.1/packet.schema.json",
  "title": "Agent Handoff Packet v0.1",
  "type": "object",
  "required": [
    "packet_type",
    "goal",
    "constraints",
    "acceptance",
    "failure_boundary",
    "return_required"
  ],
  "properties": {
    "packet_type": {
      "type": "string",
      "enum": [
        "handoff",
        "context",
        "task",
        "verification_report",
        "decision_record"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "target_agent": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "failure_boundary": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "return_required": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "human_brief": {
      "type": "string"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
